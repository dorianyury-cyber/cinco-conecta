rules_version = '2';

// Cinco Conecta — plataforma protegida de Cinco S.A.S.
// "staff" representa a TODOS los empleados con acceso (no solo Talento
// Humano): rol "admin" gestiona vacantes/candidatos/empleados/encuestas/
// comunicados; rol "empleado" tiene acceso regular (reconocer, ver
// comunicados, responder encuestas). "vacantes" y "comunicados"/
// "encuestas" son de lectura para cualquier empleado; "candidatos" y las
// respuestas de encuesta nunca son accesibles directo desde el cliente —
// todo pasa por Cloud Functions con el Admin SDK.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function staffDoc() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }

    function isEmpleado() {
      return isSignedIn() && staffDoc().estado == 'activo';
    }

    function isAdmin() {
      return isEmpleado() && staffDoc().rol == 'admin';
    }

    match /staff/{uid} {
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow list: if isEmpleado();
      allow write: if false;
    }

    match /vacantes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /candidatos/{id} {
      allow read, write: if isAdmin();
    }

    match /reconocimientos/{id} {
      allow read: if isEmpleado();
      allow create: if isEmpleado() && request.resource.data.deAutorUid == request.auth.uid;
      // Solo se permite modificar el arreglo de "me gusta" desde el cliente;
      // el resto de campos del reconocimiento son inmutables una vez creado.
      allow update: if isEmpleado()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['megusta']);
      allow delete: if isAdmin();
    }

    match /encuestas/{id} {
      allow read: if isEmpleado();
      allow write: if isAdmin();

      // Cada quien puede ver si YA votó esta encuesta (para no mostrarle de
      // nuevo el formulario), pero nunca puede escribir aquí directo — solo
      // la Cloud Function responderEncuesta lo hace, y nadie puede leer el
      // voto de otra persona.
      match /votos/{uid} {
        allow get: if isSignedIn() && request.auth.uid == uid;
        allow list, write: if false;
      }
    }

    match /comunicados/{id} {
      allow read: if isEmpleado();
      allow write: if isAdmin();
    }

    // Las respuestas de encuesta deben quedar anónimas (sin uid) y no se
    // puede confiar en el cliente para impedir el doble voto sin revelar
    // quién respondió — por eso solo se escriben desde la Cloud Function
    // responderEncuesta. El admin sí puede LEERLAS (para ver resultados y
    // promedios), pero como nunca tienen uid, siguen siendo anónimas.
    match /encuestaRespuestas/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---- Sistema SGI-HSEQ ----

    // Cualquier empleado ve los incidentes (transparencia de seguridad),
    // pero se crean solo desde la Cloud Function reportarIncidente (para
    // poder subir la foto con el Admin SDK sin abrir Storage al público).
    // Solo el admin los edita/cierra.
    match /incidentes/{id} {
      allow read: if isEmpleado();
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // El admin crea/borra acciones correctivas; el responsable asignado
    // puede actualizar únicamente su propio avance (estado/evidencia), no
    // reasignarla ni tocar el resto de campos.
    match /accionesCorrectivas/{id} {
      allow read: if isEmpleado();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isEmpleado() && resource.data.responsableUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'evidencia']));
    }

    // El repositorio de documentos lo lee cualquier empleado; se sube solo
    // desde la Cloud Function subirDocumento (admin).
    match /documentos/{id} {
      allow read: if isEmpleado();
      allow write: if false;
    }

    match /auditorias/{id} {
      allow read: if isEmpleado();
      allow write: if isAdmin();
    }
  }
}
